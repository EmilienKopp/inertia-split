{
  "name": "splitstack/inertia-split",
  "description": "One controller, two presentations. Serve Inertia or JSON from the same action based on request context.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/contracts": "^11.0|^12.0|^13.0",
    "illuminate/routing": "^11.0|^12.0|^13.0",
    "illuminate/support": "^11.0|^12.0|^13.0",
    "inertiajs/inertia-laravel": "^2.0|^3.0"
  },
  "require-dev": {
    "larastan/larastan": "^3.10",
    "orchestra/testbench": "^9.0|^10.0",
    "pestphp/pest": "^3.0"
  },
  "scripts": {
    "test": "php vendor/bin/pest",
    "test:phpstan": "php vendor/bin/phpstan analyse --memory-limit=2G"
  },
  "autoload": {
    "psr-4": {
      "Splitstack\\InertiaSplit\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Splitstack\\InertiaSplit\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Splitstack\\InertiaSplit\\InertiaSplitServiceProvider"
      ],
      "aliases": {
        "Split": "Splitstack\\InertiaSplit\\Split\\Facades\\Split"
      }
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
